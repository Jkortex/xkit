# --- 后端配置 ---
DAILY_PORT=8080
DAILY_DB_ENGINE=sqlite
DAILY_PG_DSN=postgres://postgres:postgres@localhost:5432/daily?sslmode=disable
DAILY_SQLITE_DSN=./data/daily.db
DAILY_STORAGE_DIR=./data/storage
DAILY_LOG_LEVEL=debug
DAILY_BOOTSTRAP_ADMIN_USERNAME=admin
DAILY_BOOTSTRAP_ADMIN_PASSWORD=change_me_please
DAILY_BOOTSTRAP_DEMO_MEMOS=false
DAILY_BOOTSTRAP_DEMO_MEMOS_PATH=./docs/seeds/architecture_memos.json

# --- TTS 语音合成配置 ---
# TTS_PROVIDER: "mimo" (MiMo V2.5 TTS API, 需要 API Key) 或 "os" (系统原生 TTS, 无需配置)
TTS_PROVIDER=mimo
# TTS_API_KEY: MiMo 平台 API Key (https://platform.xiaomimimo.com)
TTS_API_KEY=
# TTS_VOICE: MiMo 预置音色名 (苏打/白桦/冰糖/茉莉/Mia/Chloe/Milo/Dean)
TTS_VOICE=苏打
# TTS_STYLE: 风格指令, 如 "磁性" "温柔" "新闻播报语调", 留空使用默认
TTS_STYLE=
# TTS_AUTO_PLAY: 新 memo 到达时自动播报 (true/false)
TTS_AUTO_PLAY=true

# --- TUI 主题配置 ---
# TUI_THEME: 主题名 (emerald/ocean/amethyst/sunset/mono)
TUI_THEME=ocean
